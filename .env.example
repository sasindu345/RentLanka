# RentLanka Environment Configuration Template
# Copy this file to '.env' and populate with your local/staging credentials.

# ----------------------------------------------------
# ✉️ Email Configuration (AWS SES, SendGrid, Smtp, Console)
# ----------------------------------------------------
EmailSettings__Provider=Console
EmailSettings__FromEmail=noreply@rentlanka.lk
EmailSettings__FromName=RentLanka Support

# AWS SES / SMTP Server Configuration (Required if Provider=Smtp)
EmailSettings__SmtpHost=email-smtp.us-east-1.amazonaws.com
EmailSettings__SmtpPort=587
EmailSettings__SmtpUser=
EmailSettings__SmtpPass=
EmailSettings__EnableSsl=true

# SendGrid Configuration (Required if Provider=SendGrid)
EmailSettings__ApiKey=
